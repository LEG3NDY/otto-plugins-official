{
  "name": "html-lsp",
  "version": "0.1.1",
  "description": "HTML code intelligence through vscode-html-language-server.",
  "author": {
    "name": "OttoAI",
    "url": "https://github.com/LEG3NDY/otto-plugins-official"
  },
  "homepage": "https://github.com/LEG3NDY/otto-plugins-official",
  "repository": "https://github.com/LEG3NDY/otto-plugins-official",
  "license": "Apache-2.0",
  "keywords": ["lsp", "html", "code-intelligence"],
  "lspServers": {
    "html": {
      "command": "${OTTO_PLUGIN_ROOT}/node_modules/.bin/vscode-html-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".html": "html",
        ".htm": "html"
      },
      "transport": "stdio"
    }
  }
}
