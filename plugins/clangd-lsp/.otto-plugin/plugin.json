{
  "name": "clangd-lsp",
  "version": "0.1.0",
  "description": "C, C++, Objective-C, and Objective-C++ code intelligence through clangd.",
  "author": {
    "name": "OttoAI",
    "url": "https://github.com/LEG3NDY/otto-plugins-official"
  },
  "homepage": "https://github.com/LEG3NDY/otto-plugins-official",
  "repository": "https://github.com/LEG3NDY/otto-plugins-official",
  "license": "Apache-2.0",
  "keywords": ["lsp", "c", "cpp", "clangd", "code-intelligence"],
  "lspServers": {
    "clangd": {
      "command": "clangd",
      "extensionToLanguage": {
        ".c": "c",
        ".h": "c",
        ".cc": "cpp",
        ".cpp": "cpp",
        ".cxx": "cpp",
        ".hpp": "cpp",
        ".hh": "cpp",
        ".hxx": "cpp",
        ".m": "objective-c",
        ".mm": "objective-cpp"
      },
      "transport": "stdio"
    }
  }
}
