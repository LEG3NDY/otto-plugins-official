{
  "name": "markdown-lsp",
  "version": "0.1.0",
  "description": "Markdown code intelligence through Marksman.",
  "author": {
    "name": "OttoAI",
    "url": "https://github.com/LEG3NDY/otto-plugins-official"
  },
  "homepage": "https://github.com/LEG3NDY/otto-plugins-official",
  "repository": "https://github.com/LEG3NDY/otto-plugins-official",
  "license": "Apache-2.0",
  "keywords": ["lsp", "markdown", "docs", "code-intelligence"],
  "lspServers": {
    "markdown": {
      "command": "marksman",
      "args": ["server"],
      "extensionToLanguage": {
        ".md": "markdown",
        ".markdown": "markdown"
      },
      "transport": "stdio"
    }
  }
}
