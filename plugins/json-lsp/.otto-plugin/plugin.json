{
  "name": "json-lsp",
  "version": "0.1.0",
  "description": "JSON and JSONC code intelligence through vscode-json-language-server.",
  "author": {
    "name": "OttoAI",
    "url": "https://github.com/LEG3NDY/otto-plugins-official"
  },
  "homepage": "https://github.com/LEG3NDY/otto-plugins-official",
  "repository": "https://github.com/LEG3NDY/otto-plugins-official",
  "license": "Apache-2.0",
  "keywords": ["lsp", "json", "jsonc", "code-intelligence"],
  "lspServers": {
    "json": {
      "command": "vscode-json-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".json": "json",
        ".jsonc": "jsonc"
      },
      "transport": "stdio"
    }
  }
}
