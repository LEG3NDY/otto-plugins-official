{
  "name": "gopls-lsp",
  "version": "0.1.0",
  "description": "Go code intelligence through gopls.",
  "author": {
    "name": "OttoAI",
    "url": "https://github.com/LEG3NDY/otto-plugins-official"
  },
  "homepage": "https://github.com/LEG3NDY/otto-plugins-official",
  "repository": "https://github.com/LEG3NDY/otto-plugins-official",
  "license": "Apache-2.0",
  "keywords": ["lsp", "go", "gopls", "code-intelligence"],
  "lspServers": {
    "go": {
      "command": "gopls",
      "extensionToLanguage": {
        ".go": "go",
        ".mod": "go.mod",
        ".sum": "go.sum"
      },
      "transport": "stdio"
    }
  }
}
