        "html",
        "code-intelligence"
      ],
      "source": "./plugins/html-lsp",
      "version": "0.1.0",
      "strict": true,
      "lspServers": {
        "html": {
          "command": "vscode-html-language-server",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".html": "html",
            ".htm": "html"
          },
          "transport": "stdio"
        }
      }
    },
